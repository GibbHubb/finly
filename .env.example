# ── Backend ──────────────────────────────────────────────────────────────────
# SQLite (default dev). For PostgreSQL use: postgresql://user:pass@db:5432/finly
DATABASE_URL=sqlite:///./finly.db

# Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
